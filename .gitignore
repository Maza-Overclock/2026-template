# ──────────────────────────────────────────────
# MAZA Overclock — Generic .gitignore
# Teams may delete sections they do not need.
# ──────────────────────────────────────────────

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Editors & IDEs
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Environment & secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Node.js ──────────────────────────────────
node_modules/
dist/
build/
.next/
.nuxt/
.output/
.cache/
.parcel-cache/
.turbo/
coverage/
.nyc_output/
*.tsbuildinfo

# ── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
venv/
env/
.Python
pip-log.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover

# ── Go ───────────────────────────────────────
bin/
vendor/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work
go.work.sum

# ── Rust ─────────────────────────────────────
target/
debug/
release/
**/*.rs.bk
Cargo.lock

# ── Java ─────────────────────────────────────
*.class
*.jar
*.war
*.ear
hs_err_pid*
.gradle/
build/
out/
target/
.mtj.tmp/
*.iml

# ── .NET ─────────────────────────────────────
bin/
obj/
*.user
*.suo
*.cache
*.dll
*.exe
*.pdb
*.nupkg
packages/
*.DotSettings.user
project.lock.json
project.fragment.lock.json
artifacts/

# ── General build artifacts ──────────────────
*.o
*.a
*.so
*.dylib
*.zip
*.tar.gz
*.rar
